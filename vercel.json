{
  "crons": [
    {
      "path": "/api/cron/jobs?job=noise-zones",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/jobs?job=keepalive",
      "schedule": "0 6 * * *"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    },
    "api/cron/jobs.js": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; worker-src blob:; object-src 'none'; frame-src https://www.openstreetmap.org; connect-src 'self' https://api.cerebras.ai https://*.turso.io https://*.upstash.io https://www.google-analytics.com https://analytics.google.com https://news.google.com https://redfin-public-data.s3.amazonaws.com https://api2.realtor.ca https://api.realtor.ca https://*.ingest.sentry.io https://o4511169279492096.ingest.us.sentry.io https://nominatim.openstreetmap.org https://api.open-meteo.com https://archive-api.open-meteo.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-site"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api|sitemap\\.xml|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
