# Auth
AUTH_SECRET=your_secret_here
CEREBRAS_ENCRYPTION_KEY=64_hex_chars_here

# Database
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=your_token_here

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Email (Resend)
RESEND_API_KEY=your_key_here

# External APIs — server-side only, never use VITE_ prefix for secrets
HUD_TOKEN=your_hud_token_here
CENSUS_API_KEY=your_census_key_here

# Admin
ADMIN_EMAILS=you@example.com
BASE_URL=https://dwelling.one
ALLOWED_ORIGIN=https://dwelling.one

# Optional: platform-level Cerebras key (fallback if user has no key saved)
CEREBRAS_API_KEY=your_cerebras_key_here

# Stripe (test mode — use sk_test_... keys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_ANNUAL=price_your_annual_price_id
# Test card: 4242 4242 4242 4242, any future expiry, any CVC
